# ── SUPABASE ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── EMAIL SERVICE (Resend) ────────────────────────
# Đăng ký tại: https://resend.com (free tier: 3000 email/tháng)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@namngantravel.com
ADMIN_NOTIFY_EMAIL=admin@namngantravel.com

# ── GOOGLE APIs ───────────────────────────────────
GOOGLE_SHEETS_API_KEY=your-sheets-api-key
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_DOCS_API_KEY=your-docs-api-key

# ── WEBHOOKS & INTEGRATIONS ───────────────────────
WEBHOOK_SECRET=your-random-secret-string
MODA_API_KEY=
N8N_WEBHOOK_URL=

# ── DIRECTUS CMS ──────────────────────────────────
# 1. Self-host Directus tại domain của bạn (ví dụ: cms.namngantravel.com)
# 2. Kết nối Supabase PostgreSQL:
#    DB_CLIENT=pg
#    DB_CONNECTION_STRING=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#    (Lấy từ Supabase Dashboard → Settings → Database → URI mode)
# 3. Tạo token: Directus Admin → Settings → API Access Tokens → quyền read-only
DIRECTUS_URL=https://cms.namngantravel.com
DIRECTUS_STATIC_TOKEN=your-directus-static-token

# ── APP ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
